@page "{id}"
@model Morassalat.Pages.Users.DeleteModel
@{
    ViewData["Title"] = "Delete User";
}

<h1>Delete User</h1>

<h3>Are you sure you want to delete this user?</h3>

<div>
    <dl class="row">
        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">@Model.UserToDelete.Email</dd>

        <dt class="col-sm-3">Roles</dt>
        <dd class="col-sm-9">@Model.UserToDelete.Roles</dd>

        <dt class="col-sm-3">Tenants</dt>
        <dd class="col-sm-9">@Model.UserToDelete.Tenants</dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="UserToDelete.Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
