@page
@model Morassalat.Pages.ApplicationParameters.IndexModel
@{
    ViewData["Title"] = "Application Parameters";
}

<h1>Application Parameters</h1>

<p>
    <a asp-page="Create" class="btn btn-primary">Create New</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Application Name</th>
            <th>Tenant</th>
            <th>Contact Email</th>
            <th>Administrative Year</th>
            <th>Website</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.ApplicationParameters)
        {
            <tr>
                <td>@item.ApplicationName</td>
                <td>@item.Tenant.Name</td>
                <td>@item.ContactEmail</td>
                <td>@item.CurrentAdministrativeYear</td>
                <td>@item.Website</td>
                <td>
                    <a asp-page="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-page="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-page="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
