@page "{id:int}"
@model Morassalat.Pages.ApplicationParameters.DeleteModel
@{
    ViewData["Title"] = "Delete Application Parameter";
}

<h1>Delete Application Parameter</h1>

<h3>Are you sure you want to delete this application parameter?</h3>

<div>
    <dl class="row">
        <dt class="col-sm-3">Tenant</dt>
        <dd class="col-sm-9">@Model.ApplicationParameter.Tenant.Name</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ApplicationParameter.ApplicationName)</dt>
        <dd class="col-sm-9">@Model.ApplicationParameter.ApplicationName</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ApplicationParameter.ContactEmail)</dt>
        <dd class="col-sm-9">@Model.ApplicationParameter.ContactEmail</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ApplicationParameter.CurrentAdministrativeYear)</dt>
        <dd class="col-sm-9">@Model.ApplicationParameter.CurrentAdministrativeYear</dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="ApplicationParameter.Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
